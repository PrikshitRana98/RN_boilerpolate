{
  "name": "rn_boilerplate",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "gc": "cd android && ./gradlew clean ",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "bundle:ota:android": "mkdir -p ota-bundles/android && npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output ota-bundles/android/index.android.bundle --assets-dest ota-bundles/android && cd ota-bundles/android && zip -r ../android-bundle.zip .",
    "bundle:ota:ios": "mkdir -p ota-bundles/ios && npx react-native bundle --platform ios --dev false --entry-file index.js --bundle-output ota-bundles/ios/main.jsbundle --assets-dest ota-bundles/ios && cd ota-bundles/ios && zip -r ../ios-bundle.zip ."
  },
  "dependencies": {
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-firebase/app": "^23.4.0",
    "@react-native-firebase/messaging": "^23.4.0",
    "@react-native/new-app-screen": "^0.81.4",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.26",
    "@reduxjs/toolkit": "^2.8.2",
    "axios": "^1.11.0",
    "i18next": "^25.4.2",
    "intl-pluralrules": "^2.0.1",
    "patch-package": "^8.0.0",
    "react": "19.1.0",
    "react-i18next": "^15.7.3",
    "react-native": "0.81.4",
    "react-native-blob-util": "^0.24.10",
    "react-native-bootsplash": "^6.3.10",
    "react-native-mmkv": "^4.3.1",
    "react-native-modal": "^14.0.0-rc.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-ota-hot-update": "^2.4.3",
    "react-native-otp-entry": "^1.8.5",
    "react-native-reanimated": "^4.1.0",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.15.4",
    "react-native-svg": "^15.12.1",
    "react-native-svg-transformer": "^1.5.1",
    "react-native-worklets": "^0.5.0",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "rn-secure-storage": "^3.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.4",
    "@react-native/eslint-config": "0.81.4",
    "@react-native/metro-config": "0.81.4",
    "@react-native/typescript-config": "0.81.4",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
